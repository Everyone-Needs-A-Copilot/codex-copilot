  "routingEdges": [
    { "from": "any", "to": "ta", "when": "Architecture decisions, decomposition, migration, or non-trivial technical planning is needed" },
    { "from": "any", "to": "me", "when": "Implementation is ready after framing" },
    { "from": "any", "to": "qa", "when": "Verification, tests, regression analysis, or design-fidelity evidence is needed" },
    { "from": "any", "to": "doc", "when": "Durable documentation is needed" },
    { "from": "any", "to": "sec", "when": "Auth, permissions, secrets, unsafe input, PII, or trust boundaries are in scope" },
    { "from": "ind", "to": "sd", "when": "Physical-digital product direction needs service journey framing" },
    { "from": "sd", "to": "uxd", "when": "Service concept is ready for task flow and interaction design" },
    { "from": "uxd", "to": "uids", "when": "Task flow, states, and product language need visual hierarchy" },
    { "from": "uids", "to": "uid", "when": "Visual system and state styling are clear enough to implement" },
    { "from": "uid", "to": "ta", "when": "UI implementation boundaries need technical decomposition or integration planning" },
    { "from": "ta", "to": "me", "when": "Implementation boundaries and test expectations are ready" },
    { "from": "me", "to": "qa", "when": "Implementation work is complete and needs verification" }
  ],
