    },
    {
      "id": "sec",
      "skill": "agent-sec",
      "role": "explorer",
      "purpose": "Security review and threat analysis"
    },
    {
      "id": "doc",
      "skill": "agent-doc",
      "role": "default",
      "purpose": "Documentation and durable explanations"
    },
    {
      "id": "do",
      "skill": "agent-do",
      "role": "worker",
      "purpose": "Deployment, CI, and infrastructure work"
    },
    {
      "id": "sd",
      "skill": "agent-sd",
      "role": "default",
