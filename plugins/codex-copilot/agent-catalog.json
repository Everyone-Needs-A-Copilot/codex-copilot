      "purpose": "UI implementation and component construction"
    },
    {
      "id": "cw",
      "skill": "agent-cw",
      "role": "default",
      "purpose": "Product copy and tone"
    },
    {
      "id": "cco",
      "skill": "agent-cco",
      "role": "default",
