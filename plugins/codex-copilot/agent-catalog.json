    "bug": ["qa", "me", "qa"],
    "technical_feature": ["ta", "me", "qa"],
    "experience_feature": ["sd", "uxd", "uids", "uid", "ta", "me", "qa"],
    "ui_polish": ["uids", "uid", "qa"],
    "security_sensitive": ["ta", "sec", "me", "qa"],
    "infrastructure": ["do", "me", "qa"],
    "knowledge": ["kc"],
    "creative_branch": ["cco", "cw"],
    "business_advisory": ["cs", "cpa"]
